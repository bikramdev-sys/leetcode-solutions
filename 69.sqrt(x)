class Solution {
public:
    int mySqrt(int x) {
        if(x==0) return 0;
        int s=0;
        int e=x;
        long long mid=s+(e-s)/2;
        long long ans=0;
        while(s<=e){
            if(mid*mid==x){
               // return mid;
               ans=mid;
            }
            if(mid*mid>x){
                e=mid-1;
            }
            else {//(mid<x/mid){
                ans=mid;
                s=mid+1;
            }
            mid=s+(e-s)/2;

        }

        return ans;
    }
};
