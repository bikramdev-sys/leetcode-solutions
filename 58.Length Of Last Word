class Solution {
public:
    int lengthOfLastWord(string s) {
        int count=0;
        for(int i=s.length()-1;i>=0;i--){
        
              while(i>=0 && s[i]==' '){
                  i--;
            }
        for(int j=i;j>=0;j--){
            if(s[j]!=' '){
                count++;
            }
                else{
                    return count;
                }
        }
return count;
        }
     return count;
    }
};
