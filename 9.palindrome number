class Solution {
public:
    bool isPalindrome(int x) {
        int originalNum, reversedNum = 0, digit;
    
   
    originalNum = x;

    while (x > 0) {
        digit = x % 10;     
         if (reversedNum > INT_MAX / 10 || 
               (reversedNum == INT_MAX / 10 && digit > 7)){
                return false; }     
        reversedNum = reversedNum * 10 + digit; 
        x /= 10;                     
    }

    if (originalNum == reversedNum)
        return true;
   
     return false;
    }
};
