class Solution {
public:
    int findfirst(vector<int>& nums, int target) {
        int s=0;
        int e=nums.size()-1;
        int mid=s+(e-s)/2;
        int ans=-1;
         while(s<=e){
            if(nums[mid]==target){
                ans=mid;
                e=mid-1;

            }
            else if(nums[mid]>target){
            e=mid-1;
            }
            else{
                s=mid+1;
            }
            mid=s+(e-s)/2;
        }
        return ans;
    }  
     int findlast(vector<int>& nums, int target) {
        int s=0;
        int e=nums.size()-1;
        int mid=s+(e-s)/2;
        int ans=-1;
         while(s<=e){
            if(nums[mid]==target){
                ans=mid;
                s=mid+1;

            }
            else if(nums[mid]>target){
            e=mid-1;}
            else{
                s=mid+1;
            }
            mid=s+(e-s)/2;
        }
        return ans;
    } 
    vector<int> searchRange(vector<int>& nums, int target) {
        int first = findfirst(nums, target);
        int last = findlast(nums, target);
        return {first, last};    
    }
};
